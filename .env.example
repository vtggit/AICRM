# =============================================================================
# AICRM — Environment Configuration Example
# =============================================================================
# Copy this file to .env and adjust values for your environment:
#
#   cp .env.example .env
#
# Never commit .env with real secrets to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------
DB_NAME=aicrm
DB_USER=aicrm
DB_PASSWORD=change-me-in-production
DB_PORT_HOST=5432

# ---------------------------------------------------------------------------
# Backend
# ---------------------------------------------------------------------------
BACKEND_PORT_HOST=9000
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Frontend
# ---------------------------------------------------------------------------
FRONTEND_PORT_HOST=8080

# ---------------------------------------------------------------------------
# CORS
#
# Comma-separated list of allowed frontend origins.
# When running via docker-compose, the frontend container is reachable at
# http://frontend (Docker DNS).  Local dev origins are included by default.
# ---------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://frontend

# ---------------------------------------------------------------------------
# Authentication
#
# AUTH_MODE=development  → simple shared bearer token (local dev only)
# AUTH_MODE=production   → real JWT validation against IdP (JWKS)
# ---------------------------------------------------------------------------
AUTH_ENABLED=true
AUTH_MODE=development
AUTH_DEV_TOKEN=dev-secret-token
AUTH_DEV_ROLES=user

# Production auth (only used when AUTH_MODE=production):
AUTH_ISSUER=https://dev.example.com/realms/aicrm
AUTH_CLIENT_ID=aicrm-backend
AUTH_AUDIENCE=aicrm-backend
AUTH_ALGORITHMS=RS256
AUTH_JWKS_CACHE_TTL=3600
AUTH_ROLE_CLAIMS=roles,realm_access.roles,resource_access.{client_id}.roles
AUTH_GROUP_CLAIMS=groups
